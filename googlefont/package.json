{
  "name": "googlefont",
  "version": "0.0.1",
  "scripts": {
    "build": "ng build",
    "dl-font-fresca": "goog-webfont-dl -o src/font-fresca.css -p assets/Fresca -d src/assets/Fresca -a Fresca",
    "dl-font-opensans": "goog-webfont-dl -o src/font-opensans.css -p assets/OpenSans -d src/assets/OpenSans -a \"Open Sans\"",
    "ng": "ng",
    "postinstall": "npm run dl-font-opensans \u0026\u0026 npm run dl-font-fresca",
    "serve-dist": "ws --hostname localhost -d dist/app/browser -p 1234 -o --log.format stats",
    "start": "ng serve",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.5",
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/router": "21.2.5",
    "@ionic/angular": "8.8.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@ionic/angular-toolkit": "12.3.0",
    "goog-webfont-dl": "1.0.4",
    "local-web-server": "5.4.0",
    "typescript": "5.9.3",
    "prettier": "3.8.1"
  }
}
